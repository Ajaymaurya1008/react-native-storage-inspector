{
  "name": "react-native-storage-inspector",
  "version": "1.0.3",
  "description": "Storage inspector for React Native and Expo: MMKV, AsyncStorage, Keychain, Expo Secure Store",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "commit": "cz",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build": "tsup && node scripts/postbuild.js",
    "commitlint": "commitlint --from HEAD~1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "prettier --check .",
    "prepublishOnly": "npm run format:check && npm test && npm run build",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "keywords": [
    "react-native",
    "expo",
    "storage",
    "inspector",
    "mmkv",
    "async-storage",
    "keychain",
    "secure-store",
    "debug"
  ],
  "author": "Ajaymaurya1008",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ajaymaurya1008/react-native-storage-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/Ajaymaurya1008/react-native-storage-inspector/issues"
  },
  "homepage": "https://github.com/Ajaymaurya1008/react-native-storage-inspector#readme",
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native-mmkv": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "react-native-keychain": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.72.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "semantic-release": "^24.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}
