{
  "name": "react-native-storage-inspector",
  "version": "1.0.0",
  "description": "Storage inspector for React Native and Expo: MMKV, AsyncStorage, Keychain, Expo Secure Store",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "expo",
    "storage",
    "inspector",
    "mmkv",
    "async-storage",
    "keychain",
    "secure-store",
    "debug"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native-mmkv": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "react-native-keychain": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  }
}
